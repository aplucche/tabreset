{
    "manifest_version": 3,
    "name": "Tab Reset",
    "version": "1.0.0",
    "description": "Summarize and close open tabs.",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "web_accessible_resources": [
        {
            "resources": ["assets/wasm/*"],
            "matches": ["<all_urls>"]
        }
    ]
}